# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files needed for Cloud Work Spaces
!override.tf
!override.tf.json

# Include CLI commands output
*_cli.txt

# Ignore plan files
*.tfplan
*.out

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan output files
*.txt

# Ignore Mac .DS_Store files
.DS_Store

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
Thumbs.db

# Ignore Jenkins artifacts
tfplan-*.txt
tfplan-*.tfplan
outputs-*.json

# Ignore local backend config
backend-config.hcl
